#============================================================================
# SYNERGY NETWORK NODE CONTROL PANEL - ENVIRONMENT CONFIGURATION (TESTBETA)
# ============================================================================
# Copy this file to .env and fill in real values before deployment.

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# Network selection
SYNERGY_NETWORK=testbeta

# Testbeta Chain ID
SYNERGY_CHAIN_ID=338639

# Testbeta bootstrap nodes
# Format: snr://<node-address>@<hostname>:<p2p-port>
SYNERGY_BOOTSTRAP_NODES=snr://synv11lylxla8qjcrk3ef8gjlyyhew3z4mjswwwsn6zv@bootnode1.synergynode.xyz:38638,snr://synv11csyhf60yd6gp8n4wflz99km29g7fh8guxrmu04@bootnode2.synergynode.xyz:38638,snr://synv110y3fuyvqmjdp02j6m6y2rceqjp2dexwu3p6np4@bootnode3.synergynode.xyz:38638
SYNERGY_SEED_SERVERS=http://seed1.synergynode.xyz:18080,http://seed2.synergynode.xyz:18080,http://seed3.synergynode.xyz:18080
SYNERGY_BOOTSTRAP_DNS_RECORDS=_dnsaddr.bootstrap.synergynode.xyz

# Testbeta endpoints
SYNERGY_RPC_ENDPOINT=https://testbeta-core-rpc.synergy-network.io
# Optional comma-separated fallback RPC endpoints (used if the primary is down).
SYNERGY_RPC_FALLBACKS=
SYNERGY_WS_ENDPOINT=wss://testbeta-core-ws.synergy-network.io
SYNERGY_API_ENDPOINT=https://testbeta-api.synergy-network.io
SYNERGY_EXPLORER_ENDPOINT=https://testbeta-explorer.synergy-network.io
SYNERGY_INDEXER_ENDPOINT=https://testbeta-indexer.synergy-network.io
SYNERGY_FAUCET_ENDPOINT=https://testbeta-faucet.synergy-network.io
SYNERGY_EXPLORER_API_ENDPOINT=https://testbeta-atlas-api.synergy-network.io
SYNERGY_EXPLORER_RESET_ENDPOINT=https://testbeta-atlas-api.synergy-network.io/v1/admin/reindex-from-genesis
SYNERGY_WALLET_API_ENDPOINT=https://testbeta-wallet-api.synergy-network.io
SYNERGY_SXCP_API_ENDPOINT=https://testbeta-sxcp-api.synergy-network.io
SYNERGY_SXCP_WS_ENDPOINT=wss://testbeta-sxcp-ws.synergy-network.io
SYNERGY_SYNQ_VERIFY_ENDPOINT=https://testbeta-synq-verify.synergy-network.io


# ============================================================================
# BINARY DOWNLOADS & REPOSITORIES
# ============================================================================

# Repo containing the Synergy Testnet-Beta node software
SYNERGY_GITHUB_REPO=https://github.com/synergy-network-hq/synergy-testnet-beta

# Version to download (testbeta tracks latest)
SYNERGY_VERSION=latest

# ============================================================================
# UNIFIED BINARY CONFIGURATION (TESTBETA)
# ============================================================================

# We are using the unified binary "synergy-testbeta"
# Node role is selected by config + CLI flags
SYNERGY_BINARY_NAME=synergy-testbeta
SYNERGY_UNIFIED_BINARY_URL=https://testbeta.synergy-network.io/binaries/latest.json

# Binary naming model
SYNERGY_BINARY_NAMING=unified

# Platform builds
SYNERGY_BINARY_PLATFORM_LINUX_AMD64=linux-amd64
SYNERGY_BINARY_PLATFORM_LINUX_ARM64=linux-arm64
SYNERGY_BINARY_PLATFORM_DARWIN_AMD64=darwin-amd64
SYNERGY_BINARY_PLATFORM_DARWIN_ARM64=darwin-arm64
SYNERGY_BINARY_PLATFORM_WINDOWS_AMD64=windows-amd64.exe


# ============================================================================
# BUILD FROM SOURCE (fallback)
# ============================================================================

SYNERGY_BUILD_FROM_SOURCE=false
SYNERGY_SOURCE_REPO=https://github.com/synergy-network-hq/synergy-testnet-beta
SYNERGY_BUILD_COMMANDS="cargo build --release"


# ============================================================================
# NODE COMPATIBILITY MATRIX
# ============================================================================
# A single machine may run multiple logical roles using unified binary modes.

SYNERGY_COMPAT_VALIDATOR=committee,archive_validator,audit_validator
SYNERGY_COMPAT_COMMITTEE=validator
SYNERGY_COMPAT_ARCHIVE_VALIDATOR=validator
SYNERGY_COMPAT_AUDIT_VALIDATOR=validator
SYNERGY_COMPAT_RELAYER=witness,oracle
SYNERGY_COMPAT_WITNESS=relayer
SYNERGY_COMPAT_ORACLE=relayer
SYNERGY_COMPAT_UMA_COORDINATOR=cross_chain_verifier
SYNERGY_COMPAT_CROSS_CHAIN_VERIFIER=uma_coordinator
SYNERGY_COMPAT_COMPUTE=ai_inference,pqc_crypto
SYNERGY_COMPAT_AI_INFERENCE=compute
SYNERGY_COMPAT_PQC_CRYPTO=compute
SYNERGY_COMPAT_DATA_AVAILABILITY=archive_validator
SYNERGY_COMPAT_GOVERNANCE_AUDITOR=security_council
SYNERGY_COMPAT_TREASURY_CONTROLLER=security_council
SYNERGY_COMPAT_SECURITY_COUNCIL=governance_auditor,treasury_controller
SYNERGY_COMPAT_RPC_GATEWAY=indexer,observer
SYNERGY_COMPAT_INDEXER=rpc_gateway
SYNERGY_COMPAT_OBSERVER=rpc_gateway


# ============================================================================
# STAKING & BONDING REQUIREMENTS
# ============================================================================

SYNERGY_STAKE_VALIDATOR=100
SYNERGY_STAKE_COMMITTEE=100
SYNERGY_STAKE_ARCHIVE_VALIDATOR=100
SYNERGY_STAKE_AUDIT_VALIDATOR=100
SYNERGY_STAKE_RELAYER=100
SYNERGY_STAKE_WITNESS=100
SYNERGY_STAKE_ORACLE=100
SYNERGY_STAKE_UMA_COORDINATOR=100
SYNERGY_STAKE_CROSS_CHAIN_VERIFIER=100
SYNERGY_STAKE_COMPUTE=100
SYNERGY_STAKE_AI_INFERENCE=100
SYNERGY_STAKE_PQC_CRYPTO=100
SYNERGY_STAKE_DATA_AVAILABILITY=100
SYNERGY_STAKE_GOVERNANCE_AUDITOR=100
SYNERGY_STAKE_TREASURY_CONTROLLER=100
SYNERGY_STAKE_SECURITY_COUNCIL=100
SYNERGY_STAKE_RPC_GATEWAY=100
SYNERGY_STAKE_INDEXER=100
SYNERGY_STAKE_OBSERVER=100


# ============================================================================
# CONFIG TEMPLATE URLS
# ============================================================================
# NOTE: Config templates are stored locally in the templates/ directory
# No evidence found of templates being hosted online
# These URLs are left blank - templates should be bundled with the control panel
# or downloaded from the GitHub repository

SYNERGY_CONFIG_TEMPLATE_VALIDATOR=
SYNERGY_CONFIG_TEMPLATE_COMMITTEE=
SYNERGY_CONFIG_TEMPLATE_ARCHIVE_VALIDATOR=
SYNERGY_CONFIG_TEMPLATE_AUDIT_VALIDATOR=
SYNERGY_CONFIG_TEMPLATE_RELAYER=
SYNERGY_CONFIG_TEMPLATE_WITNESS=
SYNERGY_CONFIG_TEMPLATE_ORACLE=
SYNERGY_CONFIG_TEMPLATE_UMA_COORDINATOR=
SYNERGY_CONFIG_TEMPLATE_CROSS_CHAIN_VERIFIER=
SYNERGY_CONFIG_TEMPLATE_COMPUTE=
SYNERGY_CONFIG_TEMPLATE_AI_INFERENCE=
SYNERGY_CONFIG_TEMPLATE_PQC_CRYPTO=
SYNERGY_CONFIG_TEMPLATE_DATA_AVAILABILITY=
SYNERGY_CONFIG_TEMPLATE_GOVERNANCE_AUDITOR=
SYNERGY_CONFIG_TEMPLATE_TREASURY_CONTROLLER=
SYNERGY_CONFIG_TEMPLATE_SECURITY_COUNCIL=
SYNERGY_CONFIG_TEMPLATE_RPC_GATEWAY=
SYNERGY_CONFIG_TEMPLATE_INDEXER=
SYNERGY_CONFIG_TEMPLATE_OBSERVER=


# ============================================================================
# HARDWARE REQUIREMENTS CHECKS
# ============================================================================

SYNERGY_ENABLE_HW_VALIDATION=false

# Requirements are enforced dynamically by the control panel


# ============================================================================
# DEFAULT PORTS
# ============================================================================

SYNERGY_DEFAULT_P2P_PORT=38638
SYNERGY_DEFAULT_RPC_PORT=48638
SYNERGY_DEFAULT_WS_PORT=58638
SYNERGY_DEFAULT_METRICS_PORT=9090


# ============================================================================
# NODE IDENTITY & REWARD SETTINGS
# ============================================================================

SYNERGY_NODE_ADDRESS_MODE=generate
SYNERGY_REWARD_WALLET_MODE=prompt
SYNERGY_USE_NODE_ADDRESS_FOR_REWARDS=false

# When SYNERGY_USE_NODE_ADDRESS_FOR_REWARDS=true, the node's generated address
# will be used as the rewards wallet instead of prompting for a separate wallet.
# This allows the node address to hold rewards until they are cashed out.
# Note: This requires the node address to be capable of holding funds.

# Documentation
SYNERGY_DOCS_URL=https://docs.synergy-network.io
SYNERGY_DISCORD_URL=https://discord.gg/synergy
SYNERGY_SUPPORT_URL=


# ============================================================================
# MONITORING & TELEMETRY
# ============================================================================

SYNERGY_ENABLE_METRICS=true
SYNERGY_METRICS_ENDPOINT=
SYNERGY_LOG_LEVEL=info
