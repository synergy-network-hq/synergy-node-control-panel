# Synergy Atlas API
NODE_ENV=development
HOST=0.0.0.0
PORT=3020

# Postgres
DATABASE_URL=postgres://synergy:synergy@localhost:5432/synergy_explorer

# Synergy Atlas source nodes
# Primary feed: public Testnet-Beta RPC
# Fallback feed: same public RPC unless you operate a dedicated archive endpoint
SYNERGY_ENV=testnet-beta
SYNERGY_CORE_RPC_URL=https://testbeta-core-rpc.synergy-network.io
SYNERGY_CORE_RPC_FALLBACK_URL=https://testbeta-core-rpc.synergy-network.io

# CORS
CORS_ORIGIN=https://testbeta-explorer.synergy-network.io
