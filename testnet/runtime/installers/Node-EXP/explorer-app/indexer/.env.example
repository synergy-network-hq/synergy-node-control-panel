# Synergy Atlas Indexer
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://synergy:synergy@localhost:5432/synergy_explorer

# Synergy Atlas source nodes
# Primary feed: public Testnet RPC
# Fallback feed: same public RPC unless you operate a dedicated archive endpoint
SYNERGY_ENV=testnet
SYNERGY_CORE_RPC_URL=https://testnet-core-rpc.synergy-network.io
SYNERGY_CORE_RPC_FALLBACK_URL=https://testnet-core-rpc.synergy-network.io

# Indexer behavior
START_BLOCK=
POLL_INTERVAL_MS=2000
BATCH_SIZE=50
LOG_LEVEL=info
