{
  "name": "synergy-node-control-panel",
  "version": "5.4.0",
  "description": "Synergy Node Control Panel",
  "author": "Synergy Network <support@synergy-network.io>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite",
    "dev:electron": "node scripts/electron/dev-electron.mjs",
    "dev:desktop": "node scripts/electron/dev-desktop.mjs",
    "build": "vite build",
    "build:control-service": "cargo build --manifest-path control-service/Cargo.toml --bin control-service --release --no-default-features",
    "build:electron": "npm run build:bundle-prep && npm run build:control-service && node scripts/electron/prepare-runtime.mjs",
    "dist:electron": "npm run build:electron && electron-builder --config electron-builder.yml",
    "build:sidecars": "bash scripts/build-sidecars.sh",
    "build:bundle-prep": "bash scripts/release/build-bundle-prep.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^35.0.2",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.0",
    "wait-on": "^8.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0"
  }
}
