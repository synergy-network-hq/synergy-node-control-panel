{
  "$schema": "https://schemas.tauri.app/config.schema.json",
  "productName": "Synergy Devnet Control Center",
  "version": "2.3.0",
  "identifier": "com.synergy.node-monitor",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Synergy Devnet Control Center",
        "width": 1200,
        "height": 850,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src ipc: http://ipc.localhost https://api.github.com https://github.com https://objects.githubusercontent.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "capabilities": [
        "default",
        "frontend-api"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../devnet/lean15/node-inventory.csv",
      "../devnet/lean15/hosts.env.example",
      "../devnet/lean15/configs",
      "../devnet/lean15/installers",
      "../devnet/lean15/wireguard",
      "../scripts/devnet15",
      "../scripts/reset-devnet.sh",
      "../guides/NETWORK_NODE_MONITOR_USER_MANUAL.md"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/synergy-network-hq/devnet-control-panel-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "RWS8ygzZBZKPcmlpizc4as6OGRFj78WHu8Bjf9/1XQxjwN27ngCts50m"
    }
  }
}
